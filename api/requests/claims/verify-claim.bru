meta {
  name: Verify claim
  type: http
  seq: 4
}

post {
  url: {{base_url}}/claims/{{claim_id}}/verify
  body: none
  auth: none
}

headers {
  X-User-Id: {{verifier_user_id}}
}

docs {
  Requires VERIFIER or ADMIN role. Idempotent — verifying an already-verified
  claim is a no-op. Rejects expired claims.
}
