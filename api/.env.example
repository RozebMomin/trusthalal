# Environment
ENV=local
DEBUG=true

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=["http://localhost:3001","http://127.0.0.1:3001","http://localhost:3002","http://127.0.0.1:3002"]

# Database
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/trusthalal

# Domain
CLAIM_DEFAULT_EXPIRY_DAYS=90

# Google Places (server-side, for POST /admin/places/ingest)
#
# This key is used by the API to call Google's Place Details endpoint after
# the admin UI passes up a google_place_id from its Autocomplete widget.
# Keep it DIFFERENT from the admin panel's NEXT_PUBLIC_GOOGLE_MAPS_API_KEY:
#
#   * This key stays server-side — restrict it to your API server's IPs
#     and enable only the "Places API" (or "Places API (New)").
#   * The admin key is public (shipped to the browser) — restrict it by
#     HTTP referrer and enable only "Maps JavaScript API" + "Places API".
#
# Leave blank to disable the ingest endpoint entirely (the extractor + tests
# still work; only real HTTP calls to Google fail fast with a clear error).
GOOGLE_MAPS_API_KEY=

# Mapbox — alternate geocoder used by the consumer "Pick a city" picker
# and the near-me city pill (forward + reverse geocoding only; Places
# autocomplete + ingest details still go through Google).
#
# Mapbox's free tier is 100k geocoding requests/month, vs Google's
# ~40k under the $200 credit. When this token is set, the geocoding
# routes prefer Mapbox; without it they fall back to Google so
# existing deploys keep working unchanged.
#
# Get a token: https://account.mapbox.com/access-tokens — the default
# public token works fine server-side. No URL restriction needed
# since the token only ever sees daylight on this server.
MAPBOX_ACCESS_TOKEN=

# Resend — transactional email (invites, claim decisions, dispute
# outcomes, etc.). Leave blank to disable outbound email entirely;
# ``send_email`` no-ops gracefully with no key, so feature work and
# tests stay green without a live account.
#
# Get a key: https://resend.com/api-keys — scope it to "Sending
# access" only. The full-access key shouldn't sit on the API server.
# Verify ``trusthalal.org`` as a sending domain in the Resend
# dashboard before flipping the key on in prod; unverified domains
# get bounced.
RESEND_API_KEY=
# ``From:`` header — pre-formatted as ``"Display Name <mailbox>"`` so
# recipient clients render the friendly name. Override per-message
# from the call site for special cases (admin-internal mails, etc.).
RESEND_FROM_EMAIL="Trust Halal <noreply@trusthalal.org>"
# Optional ``Reply-To:`` so recipients replying land in a monitored
# inbox. Omit to drop the header entirely.
RESEND_REPLY_TO=

# Observability — Sentry (optional)
#
# Leave SENTRY_DSN blank to disable. The SDK no-ops when unset, so
# there's nothing to clean up locally — drop a DSN in to turn it on.
#
# Get a DSN: sentry.io → Projects → trusthalal-api → Settings → Client Keys.
# Use the same project for staging + prod, distinguished by APP_ENV below.
SENTRY_DSN=
# Defaults to 0.1 (10% of requests get performance traces). Bump to 1.0
# in dev when investigating something specific. Profiles default 0.0.
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
# Tags Sentry events with the running environment + git SHA so issues
# can be filtered. APP_RELEASE_SHA can be wired to the platform's git-
# commit env var (Render: ``RENDER_GIT_COMMIT`` is auto-populated).
APP_ENV=development
APP_RELEASE_SHA=

# Rate limiting — Redis (optional)
#
# Leave blank for in-memory counters (single-instance, resets on
# deploy). Set to a Redis URL like ``redis://default:pass@host:6379/0``
# when scaling out or when limits should survive deploys.
RATE_LIMIT_REDIS_URL=

# Review text moderation — Cloud Natural Language
#
# Screens review bodies, owner replies and report details on submit. Defaults
# to TRUE in the app so a config slip fails loudly rather than quietly
# publishing unscreened text. Set to false ONLY for local dev without a key —
# with it true and no key, the API refuses rather than degrading to allow-all.
#
# Reuses GOOGLE_MAPS_API_KEY above. Two one-time steps in GCP, and the second
# is the one people miss:
#   1. Enable "Cloud Natural Language API" (language.googleapis.com) on the
#      project — APIs & Services > Library.
#   2. Add it to the KEY's API restrictions — APIs & Services > Credentials >
#      the key > API restrictions. A key restricted to Maps/Places/Vision will
#      403 on Natural Language until it's listed there too.
TEXT_MODERATION_ENABLED=true

# Confidence thresholds, 0.0-1.0. Deliberately permissive: the failure that
# matters isn't profanity slipping through (the report queue catches that),
# it's a legitimate halal complaint being silently refused. Every block is
# logged with its scores — read a couple hundred before tightening these.
TEXT_MODERATION_BLOCK_THRESHOLD=0.80
TEXT_MODERATION_WARN_THRESHOLD=0.55

# Salt for the pseudonymised actor hash on place_signals (engagement capture).
# Set a real random value in production. Rotating it breaks per-day
# deduplication for the day it changes — see docs/trending-data-capture.md.
PLACE_SIGNAL_SECRET=dev-insecure-change-me

# ---------------------------------------------------------------------------
# Bot protection — Cloudflare Turnstile (app/core/turnstile.py)
# ---------------------------------------------------------------------------
# Off by default. Set ENABLED=true and provide the SECRET KEY (from the
# Cloudflare Turnstile dashboard — the widget's site key goes in the web
# apps as NEXT_PUBLIC_TURNSTILE_SITE_KEY, this is the paired secret).
# Fails closed by default: a Cloudflare outage blocks signups. FAIL_OPEN is
# the emergency valve. REQUIRE_MOBILE stays false until the app ships a
# Turnstile widget, or it breaks signup in the released app.
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
TURNSTILE_FAIL_OPEN=false
TURNSTILE_REQUIRE_MOBILE=false
