# Environment
ENV=local
DEBUG=true

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=["http://localhost:3001","http://127.0.0.1:3001","http://localhost:3002","http://127.0.0.1:3002"]

# Database
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/trusthalal

# Domain
CLAIM_DEFAULT_EXPIRY_DAYS=90

# Google Places (server-side, for POST /admin/places/ingest)
#
# This key is used by the API to call Google's Place Details endpoint after
# the admin UI passes up a google_place_id from its Autocomplete widget.
# Keep it DIFFERENT from the admin panel's NEXT_PUBLIC_GOOGLE_MAPS_API_KEY:
#
#   * This key stays server-side — restrict it to your API server's IPs
#     and enable only the "Places API" (or "Places API (New)").
#   * The admin key is public (shipped to the browser) — restrict it by
#     HTTP referrer and enable only "Maps JavaScript API" + "Places API".
#
# Leave blank to disable the ingest endpoint entirely (the extractor + tests
# still work; only real HTTP calls to Google fail fast with a clear error).
GOOGLE_MAPS_API_KEY=
