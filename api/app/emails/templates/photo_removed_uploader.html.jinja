{# Photo takedown notice. Mandatory category — no unsubscribe.

   Required context: preheader, place_name, reason, place_url
#}{% extends "_base.html.jinja" %}

{% block content %}
<h1 style="margin: 0 0 16px 0; font-size: 22px; line-height: 1.3; font-weight: 700; color: #1a1a1a;">
  We removed your photo
</h1>

<p style="margin: 0 0 16px 0;">
  This is about a photo you added to {{ place_name }}.
</p>

{% if reason %}
<p style="margin: 0 0 8px 0; color: #555;">Why:</p>
<p style="margin: 0 0 20px 0; padding: 12px 16px; background-color: #f6f7f6; border-radius: 8px; color: #333;">
  {{ reason }}
</p>
{% endif %}

<p style="margin: 0 0 16px 0; color: #555;">
  Photos of what a restaurant actually served are welcome here, including
  unflattering ones — they're a large part of what makes Trust Halal worth
  reading. Restaurants can report a photo but can't remove one; this decision
  was made by our team.
</p>

<p style="margin: 24px 0;">
  <a class="th-button" href="{{ place_url }}"
     style="display: inline-block; background-color: #6f8b3e; color: #ffffff; text-decoration: none; font-weight: 600; padding: 12px 22px; border-radius: 8px;">
    View the restaurant
  </a>
</p>

<p style="margin: 0; font-size: 13px; color: #888;">
  If you think we got this wrong, reply to this email.
</p>
{% endblock %}
