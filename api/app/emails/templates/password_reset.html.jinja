{# Password-reset email.

   Sent from POST /auth/forgot-password after a reset token is minted —
   carries the one-time URL the recipient opens to choose a new password.

   Required context:
     * ``preheader``    — short text shown in inbox previews
     * ``display_name`` — recipient's name (or empty string if unknown)
     * ``reset_url``    — pre-baked /reset-password URL with token
     * ``ttl_minutes``  — minutes until the link expires
#}{% extends "_base.html.jinja" %}

{% block content %}
<h1 style="margin: 0 0 16px 0; font-size: 22px; line-height: 1.3; font-weight: 700; color: #1a1a1a;">
  {% if display_name %}Hi {{ display_name }},{% else %}Reset your password{% endif %}
</h1>

<p style="margin: 0 0 16px 0;">
  We got a request to reset the password on your Trust Halal account.
  Open the link below to choose a new one — it's single-use and expires
  shortly.
</p>

<p style="margin: 24px 0;">
  <a class="th-button" href="{{ reset_url }}"
     style="display: inline-block; background-color: #6f8b3e; color: #ffffff; text-decoration: none; font-weight: 600; padding: 12px 22px; border-radius: 8px;">
    Reset my password
  </a>
</p>

<p style="margin: 0 0 8px 0; color: #555;">
  Or paste this URL into a browser:
</p>
<p style="margin: 0 0 24px 0; word-break: break-all;">
  <a href="{{ reset_url }}" style="color: #6f8b3e; text-decoration: underline;">{{ reset_url }}</a>
</p>

<p style="margin: 0; font-size: 13px; color: #888;">
  This link expires in {{ ttl_minutes }} minute{{ "" if ttl_minutes == 1 else "s" }}.
  If you didn't request a password reset you can safely ignore this
  email — your password won't change until the link is used.
</p>
{% endblock %}
