{# Halal claim approved — sent to the owner who submitted the claim.

   Required context:
     * preheader     — inbox preview text
     * display_name  — owner's name (may be empty)
     * place_name    — the restaurant's name
     * tier_label    — friendly validation tier ("Trust Halal Verified", etc.)
     * portal_url    — deep link to the claim in the owner portal
     * unsubscribe_url — None for this (transactional) email
#}{% extends "_base.html.jinja" %}

{% block content %}
<h1 style="margin: 0 0 16px 0; font-size: 22px; line-height: 1.3; font-weight: 700; color: #1a1a1a;">
  {% if display_name %}Good news, {{ display_name }}.{% else %}Your halal claim was approved.{% endif %}
</h1>

<p style="margin: 0 0 16px 0;">
  <strong>{{ place_name }}</strong> is now live on Trust Halal as
  <strong>{{ tier_label }}</strong>. Diners searching for halal food can see
  its trust profile.
</p>

<p style="margin: 24px 0;">
  <a class="th-button" href="{{ portal_url }}"
     style="display: inline-block; background-color: #6f8b3e; color: #ffffff; text-decoration: none; font-weight: 600; padding: 12px 22px; border-radius: 8px;">
    View your listing
  </a>
</p>

<p style="margin: 0; font-size: 13px; color: #888;">
  Keep your profile current — hours, photos, and certificates — so diners
  always see the latest.
</p>
{% endblock %}
