{# The restaurant answered a diner's review.

   Required context: preheader, place_name, reply_excerpt, place_url
#}{% extends "_base.html.jinja" %}

{% block content %}
<h1 style="margin: 0 0 16px 0; font-size: 22px; line-height: 1.3; font-weight: 700; color: #1a1a1a;">
  {{ place_name }} replied to your review
</h1>

<p style="margin: 0 0 8px 0; color: #555;">They wrote:</p>

<p style="margin: 0 0 20px 0; padding: 12px 16px; background-color: #e9f8f1; border-radius: 8px; color: #14532d;">
  {{ reply_excerpt }}
</p>

<p style="margin: 24px 0;">
  <a class="th-button" href="{{ place_url }}"
     style="display: inline-block; background-color: #6f8b3e; color: #ffffff; text-decoration: none; font-weight: 600; padding: 12px 22px; border-radius: 8px;">
    See the conversation
  </a>
</p>

<p style="margin: 0; font-size: 13px; color: #888;">
  You can update your review any time if what you saw has changed.
</p>
{% endblock %}
