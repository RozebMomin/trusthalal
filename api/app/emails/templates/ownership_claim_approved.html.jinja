{% extends "_base.html.jinja" %}
{% block content %}
<h1 style="margin: 0 0 16px 0; font-size: 22px; line-height: 1.3; font-weight: 700; color: #1a1a1a;">
  {% if display_name %}Hi {{ display_name }},{% else %}You&rsquo;re confirmed as the owner{% endif %}
</h1>
<p style="margin: 0 0 16px 0;">
  Your ownership claim for <strong>{{ place_name }}</strong> is approved &mdash; the
  listing is now tied to your account.
</p>
<p style="margin: 0 0 16px 0;">
  Last step: confirm the halal details diners see &mdash; menu coverage, slaughter
  method, and your certificate if you have one.
</p>
<p style="margin: 24px 0;">
  <a class="th-button" href="{{ portal_url }}"
     style="display: inline-block; background-color: #6f8b3e; color: #ffffff; text-decoration: none; font-weight: 600; padding: 12px 22px; border-radius: 8px;">
    Confirm halal details
  </a>
</p>
{% endblock %}
