{# Invite / set-password email.

   Sent from ``admin_create_user`` after ``mint_invite`` returns —
   carries the one-time URL the recipient opens to pick a password
   and finish onboarding.

   Required context:
     * ``preheader`` — short text shown in inbox previews
     * ``display_name`` — recipient's name (or empty string if
       unknown; the template handles that)
     * ``invite_url``  — pre-baked /set-password URL with token
     * ``role_label``  — friendly role string (e.g., "restaurant
       owner", "verifier", "admin") for the body copy
     * ``ttl_days``    — number of days until the link expires
#}{% extends "_base.html.jinja" %}

{% block content %}
<h1 style="margin: 0 0 16px 0; font-size: 22px; line-height: 1.3; font-weight: 700; color: #1a1a1a;">
  {% if display_name %}Welcome, {{ display_name }}.{% else %}You're invited to Trust Halal.{% endif %}
</h1>

<p style="margin: 0 0 16px 0;">
  An account has been created for you as a {{ role_label }}. Open the
  link below to choose a password and finish setting things up — the
  link is single-use and signs you in automatically.
</p>

<p style="margin: 24px 0;">
  <a class="th-button" href="{{ invite_url }}"
     style="display: inline-block; background-color: #6f8b3e; color: #ffffff; text-decoration: none; font-weight: 600; padding: 12px 22px; border-radius: 8px;">
    Set up my account
  </a>
</p>

<p style="margin: 0 0 8px 0; color: #555;">
  Or paste this URL into a browser:
</p>
<p style="margin: 0 0 24px 0; word-break: break-all;">
  <a href="{{ invite_url }}" style="color: #6f8b3e; text-decoration: underline;">{{ invite_url }}</a>
</p>

<p style="margin: 0; font-size: 13px; color: #888;">
  This link expires in {{ ttl_days }} day{{ "" if ttl_days == 1 else "s" }}.
  If you weren't expecting this email you can safely ignore it — no
  account is created until the link is used.
</p>
{% endblock %}
