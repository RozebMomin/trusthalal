{% extends "_base.html.jinja" %}
{% block content %}
{% if accepted %}
<h1 style="margin: 0 0 16px 0; font-size: 22px; line-height: 1.3; font-weight: 700; color: #1a1a1a;">
  {% if display_name %}Thank you, {{ display_name }}.{% else %}Your visit was accepted{% endif %}
</h1>
<p style="margin: 0 0 16px 0;">
  Your verification visit to <strong>{{ place_name }}</strong> was accepted.
  {{ place_name }} is now <strong>Trust Halal Verified</strong> thanks to you.
</p>
{% else %}
<h1 style="margin: 0 0 16px 0; font-size: 22px; line-height: 1.3; font-weight: 700; color: #1a1a1a;">
  {% if display_name %}Hi {{ display_name }},{% else %}An update on your visit{% endif %}
</h1>
<p style="margin: 0 0 16px 0;">
  Your verification visit to <strong>{{ place_name }}</strong> wasn&rsquo;t
  accepted this time.
</p>
{% if decision_note %}
<p style="margin: 0 0 16px 0; padding: 12px 14px; background: #f6f6f7; border-radius: 8px; color: #444;">
  <strong>Trust Halal said:</strong> {{ decision_note }}
</p>
{% endif %}
{% endif %}
<p style="margin: 24px 0;">
  <a class="th-button" href="{{ place_url }}"
     style="display: inline-block; background-color: #6f8b3e; color: #ffffff; text-decoration: none; font-weight: 600; padding: 12px 22px; border-radius: 8px;">
    View the place
  </a>
</p>
{% endblock %}
