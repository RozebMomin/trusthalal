# Copy to `.env` (gitignored) and fill in. These are YOUR desktop's creds.

# Production database — the real data this tool reads/writes.
# Use the SQLAlchemy/psycopg URL form, e.g.:
#   postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
#
# IMPORTANT: this runs inside a container, so HOST must be reachable from the
# container — NOT "localhost"/"127.0.0.1" (that's the container itself).
#   * Hosted DB (Supabase/Render/etc): use its real hostname.
#   * DB or tunnel on your Mac's localhost: use host.docker.internal instead,
#     e.g. postgresql+psycopg://USER:PASS@host.docker.internal:5432/DBNAME
PROD_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME

# Google Places server key (the same key the API uses for ingestion/resync).
GOOGLE_MAPS_API_KEY=

# Seconds to sleep between Google resync calls (rate limiting / cost control).
OPS_THROTTLE_SECONDS=0.5

# Supabase Storage — only needed for the hero-image import (writes photo bytes
# to the public place-photos bucket). Same values the API uses on Render.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PHOTOS_BUCKET=place-photos
