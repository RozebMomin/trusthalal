# Local dev environment for the consumer site.
#
# Copy to .env.local and fill in the values. .env.local is gitignored
# so secrets stay out of the repo.

# Base URL of the Trust Halal API. The site makes browser fetches
# here with credentials: "include" so the session cookie set by
# /auth/login is sent on every request. No trailing slash.
#
# Local dev:  http://localhost:8000
# Prod:       https://api.trusthalal.org
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Public, canonical URL of the consumer site. Used by the metadata
# helpers (Open Graph, sitemap.xml, canonical links). Override on
# Vercel preview deploys to point at the preview hostname; production
# stays on the apex.
#
# Local dev:  http://localhost:3003
# Prod:       https://halalfoodnearme.com
NEXT_PUBLIC_SITE_URL=http://localhost:3003

# ---------------------------------------------------------------------------
# PostHog — product analytics (active users, top searches, funnels)
# ---------------------------------------------------------------------------
# Leave NEXT_PUBLIC_POSTHOG_KEY blank to disable analytics entirely
# (the wrapper in src/lib/analytics.ts no-ops when the key is
# missing). Local dev typically wants this blank so test traffic
# doesn't pollute the production project.
#
# Get a project key:
#   posthog.com → your project → Settings → Project API Keys.
# Use the *project* (a.k.a. public / posthog) key, NOT the personal
# API key. The project key is safe to ship to the browser.
#
# Region — PostHog cloud is split US / EU; pick whichever you signed
# up with. Defaults to https://us.i.posthog.com when unset.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---------------------------------------------------------------------------
# Sentry (browser + server)
# ---------------------------------------------------------------------------
# Leave NEXT_PUBLIC_SENTRY_DSN blank to disable. SDK no-ops with no DSN.
#
# Volume here is highest of the three apps — public consumers find the
# site via search, hit it from random networks, and have no support
# channel beyond a contact form. Ship a DSN to prod before the search
# surface goes public.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_RELEASE_SHA=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------------------------------------------------------------------------
# Sentry CI / source-map upload (Vercel build only)
# ---------------------------------------------------------------------------
# Set on the Vercel project, NOT in this file. Wrapper auto-skips
# upload when SENTRY_AUTH_TOKEN is absent so local builds don't error.
#   SENTRY_ORG=trusthalal
#   SENTRY_PROJECT=consumer
#   SENTRY_AUTH_TOKEN=...

# ---------------------------------------------------------------------------
# Cloudflare Turnstile — bot challenge on signup
# ---------------------------------------------------------------------------
# Public site key from the Turnstile dashboard (safe to ship to the browser).
# Leave blank in dev: the widget renders nothing and the API's captcha is off,
# so signup still works. In prod, set this AND the API's TURNSTILE_ENABLED +
# TURNSTILE_SECRET_KEY together — one without the other either blocks all
# signups or protects nothing.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
