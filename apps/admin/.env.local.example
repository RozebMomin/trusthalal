# Copy to .env.local and edit as needed.

# Base URL of the trusthalal-api backend.
# Using NEXT_PUBLIC_ so client components can read it too.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Google Maps JavaScript API key for the browser-side Places Autocomplete
# widget used in the "New place" dialog. Restrict this key to:
#   - HTTP referrers: http://localhost:3001/*, plus your real admin origin(s)
#   - APIs enabled: Maps JavaScript API, Places API (or Places API New)
#
# Leave empty to disable the Autocomplete widget; the panel still loads, but
# the New Place dialog will show a configuration banner instead of the input.
#
# IMPORTANT: This key is shipped to the browser. It must be DIFFERENT from the
# trusthalal-api's GOOGLE_MAPS_API_KEY (which is used for billed Place Details
# calls and must stay server-side, restricted to the API server's IPs).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# Sentry (browser + server)
# ---------------------------------------------------------------------------
# Leave NEXT_PUBLIC_SENTRY_DSN blank to disable. SDK no-ops with no DSN.
#
# DSN must be NEXT_PUBLIC_ to ship into the browser bundle. The same DSN
# is used for the Node-runtime (server components, route handlers) via
# the SENTRY_DSN fallback in sentry.server.config.ts.
NEXT_PUBLIC_SENTRY_DSN=
# Tag events with environment + release. Pulled into both client + server
# initializers. Vercel auto-populates VERCEL_GIT_COMMIT_SHA — wire it to
# NEXT_PUBLIC_APP_RELEASE_SHA via the project env-var page if you want
# release tracking.
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_RELEASE_SHA=
# Defaults to 0.1 (10% of page transitions sampled).
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------------------------------------------------------------------------
# Sentry CI / source-map upload (Vercel build only)
# ---------------------------------------------------------------------------
# Set on the Vercel project, NOT in this file. Required for source-map
# upload to work; the wrapper auto-skips upload when SENTRY_AUTH_TOKEN
# is absent so local dev doesn't error.
#   SENTRY_ORG=trusthalal
#   SENTRY_PROJECT=admin
#   SENTRY_AUTH_TOKEN=...   (Sentry → Settings → Auth Tokens)
