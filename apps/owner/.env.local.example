# Local dev environment for the owner portal.
#
# Copy to .env.local and fill in the values. .env.local is gitignored
# so secrets stay out of the repo.

# Base URL of the Trust Halal API. The portal makes browser fetches
# here with credentials: "include" so the session cookie set by
# /auth/login is sent on every request. No trailing slash.
#
# Local dev:  http://localhost:8000
# Prod:       https://api.trusthalal.org
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
